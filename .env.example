# ── OpenCTI ──────────────────────────────────────
OPENCTI_BASE_URL=http://localhost:8080
OPENCTI_ADMIN_EMAIL=admin@tim.local
OPENCTI_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
OPENCTI_ADMIN_TOKEN=REPLACE_WITH_UUID

# ── RabbitMQ ─────────────────────────────────────
RABBITMQ_USER=tim
RABBITMQ_PASSWORD=REPLACE_WITH_PASSWORD

# ── MinIO ────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=REPLACE_WITH_PASSWORD

# ── Conectores OpenCTI ───────────────────────────
CONNECTOR_MITRE_ID=REPLACE_WITH_UUID
CONNECTOR_IPINFO_ID=REPLACE_WITH_UUID
CONNECTOR_CVE_ID=REPLACE_WITH_UUID

# ── IpInfo GeoIP (free account — https://ipinfo.io/signup) ──

# ── NVD CVE API key (optional — https://nvd.nist.gov/developers/request-an-api-key) ──
CVE_NVD_API_KEY=       # optional — higher rate limits for CVE sync

# ── Feed API Keys (all optional — feeds are disabled if key is absent) ──
OTX_API_KEY=              # optional — AlienVault OTX feed (free account at otx.alienvault.com)
MALWAREBAZAAR_AUTH_KEY=   # optional — MalwareBazaar feed (free account at abuse.ch)
THREATFOX_AUTH_KEY=       # optional — ThreatFox feed (free account at abuse.ch)
